{
    "hooks": {
        "SessionStart": [
            {
                "_source": "ai-toolkit",
                "matcher": "startup|compact",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/session-start.sh\""
                    }
                ]
            },
            {
                "_source": "ai-toolkit",
                "matcher": "startup|compact",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/mcp-health.sh\""
                    }
                ]
            },
            {
                "_source": "ai-toolkit",
                "matcher": "startup|compact",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/session-context.sh\""
                    }
                ]
            }
        ],
        "Notification": [
            {
                "_source": "ai-toolkit",
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/notify-waiting.sh\""
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "_source": "ai-toolkit",
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/guard-destructive.sh\""
                    }
                ]
            },
            {
                "_source": "ai-toolkit",
                "matcher": "Bash|Read|Edit|Write|MultiEdit|Glob|Grep|NotebookEdit|mcp__filesystem__.*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/guard-path.sh\""
                    }
                ]
            },
            {
                "_source": "ai-toolkit",
                "matcher": "Edit|Write|MultiEdit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/guard-config.sh\""
                    }
                ]
            },
            {
                "_source": "ai-toolkit",
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/commit-quality.sh\""
                    }
                ]
            },
            {
                "_source": "ai-toolkit",
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/revert-guard.sh\""
                    }
                ]
            }
        ],
        "UserPromptSubmit": [
            {
                "_source": "ai-toolkit",
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "AI_TOOLKIT_HOOK_QUIET=1 AI_TOOLKIT_HOOK_FORMAT=json \"$HOME/.softspark/ai-toolkit/hooks/user-prompt-submit.sh\""
                    }
                ]
            },
            {
                "_source": "ai-toolkit",
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/track-usage.sh\""
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "_source": "ai-toolkit",
                "matcher": "Edit|MultiEdit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/post-tool-use.sh\""
                    }
                ]
            },
            {
                "_source": "ai-toolkit",
                "matcher": "Bash|Edit|Write|MultiEdit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/governance-capture.sh\""
                    }
                ]
            },
            {
                "_source": "ai-toolkit",
                "matcher": "Bash|Edit|MultiEdit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/loop-guard.sh\""
                    }
                ]
            },
            {
                "_source": "ai-toolkit",
                "matcher": "Edit|MultiEdit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/test-cohesion.sh\""
                    }
                ]
            },
            {
                "_source": "ai-toolkit",
                "matcher": "mcp__.*__(smart_query|hybrid_search_kb|crag_search|multi_hop_search|verify_answer)|WebSearch|WebFetch",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/search-tracker.sh\""
                    }
                ]
            }
        ],
        "Stop": [
            {
                "_source": "ai-toolkit",
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/quality-check.sh\""
                    }
                ]
            },
            {
                "_source": "ai-toolkit",
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/save-session.sh\""
                    }
                ]
            },
            {
                "_source": "ai-toolkit",
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/quality-gate.sh\""
                    }
                ]
            },
            {
                "_source": "ai-toolkit",
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/stop-search-check.sh\""
                    }
                ]
            }
        ],
        "TaskCompleted": [
            {
                "_source": "ai-toolkit",
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/quality-gate.sh\""
                    }
                ]
            }
        ],
        "TeammateIdle": [
            {
                "_source": "ai-toolkit",
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "echo 'Teammate going idle. Verify: (1) All assigned files modified, (2) Tests written for changes, (3) Documentation updated if needed.'"
                    }
                ]
            }
        ],
        "SubagentStart": [
            {
                "_source": "ai-toolkit",
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/subagent-start.sh\""
                    }
                ]
            }
        ],
        "SubagentStop": [
            {
                "_source": "ai-toolkit",
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/subagent-stop.sh\""
                    }
                ]
            }
        ],
        "PreCompact": [
            {
                "_source": "ai-toolkit",
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/pre-compact.sh\""
                    }
                ]
            },
            {
                "_source": "ai-toolkit",
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/pre-compact-save.sh\""
                    }
                ]
            }
        ],
        "SessionEnd": [
            {
                "_source": "ai-toolkit",
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/session-end.sh\""
                    }
                ]
            }
        ],
        "InstructionsLoaded": [
            {
                "_source": "ai-toolkit",
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/instructions-audit.sh\""
                    }
                ]
            }
        ],
        "ConfigChange": [
            {
                "_source": "ai-toolkit",
                "matcher": "user_settings",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/config-desync-guard.sh\""
                    }
                ]
            }
        ]
    },
    "statusLine": {
        "_source": "ai-toolkit",
        "type": "command",
        "command": "bash \"$HOME/.softspark/ai-toolkit/hooks/ai-toolkit-statusline.sh\""
    }
}
