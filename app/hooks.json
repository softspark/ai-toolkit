{
    "hooks": {
        "SessionStart": [
            {
                "_source": "ai-toolkit",
                "matcher": "startup|compact",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/session-start.sh\""
                    }
                ]
            },
            {
                "_source": "ai-toolkit",
                "matcher": "startup|compact",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/mcp-health.sh\""
                    }
                ]
            },
            {
                "_source": "ai-toolkit",
                "matcher": "startup|compact",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/session-context.sh\""
                    }
                ]
            }
        ],
        "Notification": [
            {
                "_source": "ai-toolkit",
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash ~/.softspark/ai-toolkit/hooks/notify-waiting.sh"
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "_source": "ai-toolkit",
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/guard-destructive.sh\""
                    }
                ]
            },
            {
                "_source": "ai-toolkit",
                "matcher": "Bash|Read|Edit|Write|MultiEdit|Glob|Grep|NotebookEdit|mcp__filesystem__.*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/guard-path.sh\""
                    }
                ]
            },
            {
                "_source": "ai-toolkit",
                "matcher": "Edit|Write|MultiEdit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/guard-config.sh\""
                    }
                ]
            },
            {
                "_source": "ai-toolkit",
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/commit-quality.sh\""
                    }
                ]
            }
        ],
        "UserPromptSubmit": [
            {
                "_source": "ai-toolkit",
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/user-prompt-submit.sh\""
                    }
                ]
            },
            {
                "_source": "ai-toolkit",
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/track-usage.sh\""
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "_source": "ai-toolkit",
                "matcher": "Edit|MultiEdit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/post-tool-use.sh\""
                    }
                ]
            },
            {
                "_source": "ai-toolkit",
                "matcher": "Bash|Edit|Write|MultiEdit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/governance-capture.sh\""
                    }
                ]
            }
        ],
        "Stop": [
            {
                "_source": "ai-toolkit",
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/quality-check.sh\""
                    }
                ]
            },
            {
                "_source": "ai-toolkit",
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/save-session.sh\""
                    }
                ]
            }
        ],
        "TaskCompleted": [
            {
                "_source": "ai-toolkit",
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/quality-gate.sh\""
                    }
                ]
            }
        ],
        "TeammateIdle": [
            {
                "_source": "ai-toolkit",
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "echo 'Teammate going idle. Verify: (1) All assigned files modified, (2) Tests written for changes, (3) Documentation updated if needed.'"
                    }
                ]
            }
        ],
        "SubagentStart": [
            {
                "_source": "ai-toolkit",
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/subagent-start.sh\""
                    }
                ]
            }
        ],
        "SubagentStop": [
            {
                "_source": "ai-toolkit",
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/subagent-stop.sh\""
                    }
                ]
            }
        ],
        "PreCompact": [
            {
                "_source": "ai-toolkit",
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/pre-compact.sh\""
                    }
                ]
            },
            {
                "_source": "ai-toolkit",
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/pre-compact-save.sh\""
                    }
                ]
            }
        ],
        "SessionEnd": [
            {
                "_source": "ai-toolkit",
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.softspark/ai-toolkit/hooks/session-end.sh\""
                    }
                ]
            }
        ]
    }
}
